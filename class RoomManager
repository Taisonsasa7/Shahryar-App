from assets_manager import AssetsManager
from chair_registry import get_throne_data

class RoomManager:
    def _init_(self):
        self.assets = AssetsManager()
        self.room_thrones = {}

    def add_user_throne(self, user_id, chair_id):
        """ربط الكرسي بالمستخدم بعد التحقق من وجود بياناته"""
        throne_data = get_throne_data(chair_id)
        if throne_data:
            self.room_thrones[user_id] = throne_data
            print(f"تم إضافة {throne_data['name']} للمستخدم {user_id}")
        else:
            print(f"خطأ: الكرسي {chair_id} غير موجود في السجل.")

    async def handle_new_gift(self, sender_id, recipient_id):
        """محاكاة معالجة الهدية"""
        if sender_id in self.room_thrones:
            throne = self.room_thrones[sender_id]
            print(f"جارٍ تشغيل تأثير: {throne['gift_effect']} الخاص بـ {throne['name']}")
            # هنا سيتم ربط الهدية بالأصول (Assets) لاحقاً
            return True
        print("خطأ: المستخدم لا يملك كرسي فعال.")
        return False
